# Copie ce fichier en .env.local et remplis les valeurs. Ne commite jamais .env.local.

DATABASE_URL=postgresql://user:password@localhost:5432/soin_app
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# Monitoring d'erreurs (Sentry). NEXT_PUBLIC_SENTRY_DSN vient du projet Sentry créé
# sur sentry.io. SENTRY_ORG/SENTRY_PROJECT/SENTRY_AUTH_TOKEN ne sont nécessaires
# qu'au build pour uploader les source maps (facultatif en dev).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
